{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "bundle": {
    "targets": ["app", "dmg"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "bundleName": "BiNote",
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true,
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 180,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 190
        }
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "BiNote",
        "width": 1040,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true
      }
    ]
  }
}
